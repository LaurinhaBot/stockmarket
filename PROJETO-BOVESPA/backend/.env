# Database Configuration
DB_HOST=database
DB_PORT=5432
DB_USER=bovespa
DB_PASSWORD=bovespa_secret
DB_NAME=bovespa_db

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
